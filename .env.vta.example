# =============================================================================
# Trust Registry — VTA mode environment template
# =============================================================================
# Copy to `.env` and fill in the values. See VTA_SETUP.md for the end-to-end
# provisioning flow (pnm commands) that produces the credential bundle.
#
# Build the server with the `vta` feature:
#   cargo build --release --bin trust-registry --features vta
# (add a secrets backend feature, e.g. secrets-aws, if you want the offline
#  cache stored in a cloud backend rather than on local disk)
# =============================================================================

# --- DIDComm (required for VTA) ---------------------------------------------
# VTA startup only runs inside the DIDComm path. If ENABLE_DIDCOMM is not "true"
# the VTA is never consulted.
ENABLE_DIDCOMM=true
MEDIATOR_DID=did:web:CHANGEME-mediator.example

# --- VTA identity -----------------------------------------------------------
# TR_VTA_CREDENTIAL: the credential bundle recovered from `pnm bootstrap open`.
# Accepts a URI loaded value:
#   file:///path/to/vta-credential.json
#   aws_secrets://<secret-name>
#   aws_parameter_store://<param-name>
#   string://{"did":"...","privateKeyMultibase":"...","vtaDid":"...","vtaUrl":"..."}
TR_VTA_CREDENTIAL=file:///etc/trust-registry/vta-credential.json

# TR_VTA_CONTEXT_ID: the context slug (`--id`) used in `pnm contexts provision`.
# Required whenever TR_VTA_CREDENTIAL is set.
TR_VTA_CONTEXT_ID=trust-registry

# TR_VTA_URL (optional): overrides the vtaUrl field inside the credential bundle.
#TR_VTA_URL=https://vta.example.com

# TR_ALIAS (optional): profile alias. Defaults to "Trust Registry".
#TR_ALIAS=Trust Registry

# --- Offline cache (optional, recommended) ----------------------------------
# If the VTA is unreachable at boot, the last bundle is loaded from the secret
# backend selected below. With none set, it caches to ./.trust-registry on disk.
# Build with the matching `secrets-*` feature to use a cloud backend.
# NOTE: if the VTA is down AND the cache is empty, startup fails — there is no
# fallback to PROFILE_CONFIG.
#
# AWS Secrets Manager (build --features "vta,secrets-aws"):
#TR_SECRETS_AWS_SECRET_NAME=trust-registry/vta-cache
#TR_SECRETS_AWS_REGION=ap-southeast-1
#
# Other backends (build the matching secrets-* feature):
#TR_SECRETS_GCP_PROJECT=my-project
#TR_SECRETS_GCP_SECRET_NAME=trust-registry-vta-cache
#TR_SECRETS_AZURE_VAULT_URL=https://myvault.vault.azure.net
#TR_SECRETS_AZURE_SECRET_NAME=trust-registry-vta-cache
#TR_SECRETS_VAULT_ADDR=https://vault.example:8200
#TR_SECRETS_VAULT_SECRET_PATH=secret/trust-registry/vta-cache
#TR_SECRETS_VAULT_TOKEN=
#TR_SECRETS_K8S_SECRET_NAME=trust-registry-vta-cache
#TR_SECRETS_K8S_NAMESPACE=default

# NOTE: do NOT set PROFILE_CONFIG in VTA mode — VTA takes precedence and it will
# not be read.

# --- Server -----------------------------------------------------------------
LISTEN_ADDRESS=0.0.0.0:3232
CORS_ALLOWED_ORIGINS=*
ACL_MODE=ExplicitDeny
AUDIT_LOG_FORMAT=json
RUST_LOG=info
